[%General]
author=Custom
comment=Dark theme without gradients, matching backgrounds
left_tabs=true
attach_active_tab=false
no_window_pattern=true
group_toolbar_buttons=true
spread_progressbar=true
progressbar_thickness=8
composite=true
menu_shadow_depth=7
menu_blur_radius=4
spread_menuitems=true
tooltip_shadow_depth=6
tooltip_blur_radius=3
slider_width=4
slider_handle_width=18
slider_handle_length=12
scroll_min_extent=50
x11drag=all
popup_blurring=true
menubar_mouse_tracking=true
toolbutton_style=0
click_behavior=0
vertical_spin_buttons=false
translucent_windows=true
blurring=true
vertical_spin_indicators=false
merge_menubar_with_toolbar=false
scroll_arrows=false
fill_rubberband=false
small_icon_size=16
large_icon_size=32
button_icon_size=16
toolbar_icon_size=16
animate_states=true
combo_as_lineedit=true
combo_menu=true
groupbox_top_label=true
inline_spin_indicators=true
joined_inactive_tabs=true
transient_scrollbar=true
transient_groove=true
layout_spacing=3
submenu_overlap=0
tooltip_delay=-1
reduce_window_opacity=67
reduce_menu_opacity=67
opaque=kaffeine,kmplayer,subtitlecomposer,kdenlive,vlc,smplayer,smplayer2,avidemux,avidemux2_qt4,avidemux3_qt4,avidemux3_qt5,kamoso,VirtualBox,VirtualBoxVM,zen-bin,Telegram
alt_mnemonic=true
contrast=1.00
dialog_button_layout=0
drag_from_buttons=false
hide_combo_checkboxes=false
intensity=1.00
layout_margin=6
no_inactiveness=false
respect_DE=true
saturation=1.00
scrollable_menu=true
scrollbar_in_view=false
shadowless_popup=false
spin_button_width=16
submenu_delay=250
tree_branch_line=false

[GeneralColors]
window.color=#1a1111
base.color=#140c0c
alt.base.color=#231919
button.color=#231919
light.color=#3d3231
mid.light.color=#322827
dark.color=#140c0c
mid.color=#271d1d
highlight.color=#733330
inactive.highlight.color=#5d3f3d
text.color=#f1dedd
window.text.color=#f1dedd
button.text.color=#f1dedd
disabled.text.color=#a08c8b
tooltip.text.color=#f1dedd
highlight.text.color=#ffffff
link.color=#ffb3ae
link.visited.color=#e7bdb9
progress.indicator.text.color=white

[Hacks]
respect_darkness=true
transparent_dolphin_view=true
blur_translucent=true
transparent_ktitle_label=true
transparent_menutitle=true
force_size_grip=true
transparent_pcmanfm_sidepane=true
disabled_icon_opacity=100
iconless_menu=false
iconless_pushbutton=false
lxqtmainmenu_iconsize=22
normal_default_pushbutton=false
single_top_toolbar=false
tint_on_mouseover=0
transparent_pcmanfm_view=true
no_selection_tint=false
centered_forms=false
blur_only_active_window=false
kinetic_scrolling=false
middle_click_scroll=false
noninteger_translucency=false
style_vertical_toolbars=false

[PanelButtonCommand]
frame=true
frame.top=3
frame.bottom=3
frame.left=3
frame.right=3
text.margin.top=2
text.margin.bottom=2
text.margin.left=2
text.margin.right=2
text.normal.color=#d4d4d8
text.press.color=#ffffff
text.toggle.color=#ffffff
text.focus.color=#e05555
indicator.size=10
frame.expansion=10
min_width=+0.2font
min_height=+0.15font

[PanelButtonTool]
inherits=PanelButtonCommand

[ToolbarButton]
inherits=PanelButtonCommand
frame.element=tbutton
interior.element=tbutton
indicator.element=arrow

[DockTitle]
text.bold=true
text.focus.color=#d4d4d8

[LineEdit]
inherits=PanelButtonCommand
frame=true
# frame.element=lineedit
# interior.element=lineedit
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4
text.margin.left=4
text.margin.right=4

[IndicatorSpinBox]
inherits=PanelButtonCommand

[RadioButton]
inherits=PanelButtonCommand

[CheckBox]
inherits=PanelButtonCommand

[GenericFrame]
inherits=PanelButtonCommand
frame=true
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4

[DropDownButton]
inherits=PanelButtonCommand

[ToolboxTab]
inherits=PanelButtonCommand

[Tab]
inherits=PanelButtonCommand
text.margin.left=6
text.margin.right=6
text.margin.top=4
text.margin.bottom=3
frame.top=3
frame.bottom=3
frame.left=3
frame.right=3
focusFrame=true
text.press.color=#ffffff
indicator.size=12
min_width=+0.35font
min_height=+0.2font

[TabFrame]
inherits=PanelButtonCommand
frame=true
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4

[TabBarFrame]
inherits=GenericFrame
frame=true
interior=false
frame.top=0
frame.bottom=1
frame.left=0
frame.right=0

[TreeExpander]
inherits=PanelButtonCommand
frame=false
interior=false
indicator.size=10

[HeaderSection]
inherits=PanelButtonCommand
# frame.element=button

[GroupBox]
inherits=GenericFrame
interior=false
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4
text.bold=true

[SizeGrip]
inherits=PanelButtonCommand
frame=false
interior=false
indicator.element=resize-grip
indicator.size=13

[Toolbar]
inherits=PanelButtonCommand
frame.left=0
frame.right=4
frame.top=2
frame.bottom=2
indicator.size=5

[Slider]
inherits=PanelButtonCommand
# frame.element=slider
# interior.element=slider

[ScrollbarSlider]
inherits=PanelButtonCommand
interior=false
frame.top=6
frame.bottom=6
frame.left=6
frame.right=6

[ScrollbarGroove]
inherits=PanelButtonCommand
# interior.element=scrollbargroove
# frame.element=scrollbargroove

[Progressbar]
text.bold=true
text.focus.color=#ffffff

[ProgressbarContents]
inherits=PanelButtonCommand
frame=true
# frame.element=progress-pattern

[ItemView]
inherits=PanelButtonCommand
text.margin=true
# frame.element=itemview
# interior.element=itemview
frame.top=2
frame.bottom=2
frame.left=2
frame.right=2
min_height=0

[Menu]
inherits=PanelButtonCommand
text.margin=1

[MenuItem]
inherits=PanelButtonCommand
frame=true
# frame.element=menuitem
# interior.element=menuitem

[MenuBarItem]
inherits=PanelButtonCommand

[TitleBar]
inherits=PanelButtonCommand
text.bold=true
text.italic=true
text.focus.color=#e05555

[ComboBox]
inherits=LineEdit
text.margin.left=6
text.margin.right=6

[Splitter]
indicator.size=32

[WindowTranslucent]
interior=true
interior.element=window
frame.expansion=0

[Focus]
frame=true
